{
    "id": "org.kde.kimagemapeditor",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "base": "io.qt.qtwebengine.BaseApp",
    "base-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "kimagemapeditor",
    "rename-icon": "kimagemapeditor",
    "finish-args": [
        "--device=dri",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--system-talk-name=org.freedesktop.UDisks2"
