        "*.a"
    ],
    "cleanup-commands": [
        "/app/cleanup-BaseApp.sh"
    ],
    "modules": [
        {
            "name": "kimagemapeditor",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/26.04.0/src/kimagemapeditor-26.04.0.tar.xz",
                    "sha256": "71bc88310a029e71c29cd281c7ae06caf60b19fb208332a535afa7f8db9ac34b",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/kimagemapeditor-$version.tar.xz"
                    }
                }
            ]
        }
    ]
}
